# 복사해서 사용:  cp terraform.tfvars.example terraform.tfvars  후 값 채우기.
# terraform.tfvars 는 .gitignore 로 커밋 차단됨(토큰 포함 — 절대 커밋 금지).

cloudflare_api_token = "여기에-스코프드-API-토큰"      # Zone DNS/Settings/Email Routing 권한
account_id           = "여기에-account-id"
zone_id              = "여기에-zone-id"
domain               = "ddukkit.com"

server_ip     = "203.0.113.10"          # 오라클 인스턴스 공인 IP (Oracle TF의 instance_public_ip)
forward_email = "yourname@gmail.com"    # contact@ddukkit.com 을 받을 실제 메일함

# (선택) Search Console 도메인 속성 TXT — 값만(접두사 google-site-verification= 제외). 비우면 미생성.
google_site_verification = ""

proxied             = true
enable_rate_limit   = true
rate_limit_requests = 20
