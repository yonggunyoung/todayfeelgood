# dependencies
node_modules/
.pnpm-store/

# python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# next.js
.next/
out/
build/
dist/

# typescript 증분 빌드 캐시(tsc --noEmit 등이 생성 — 커밋 금지)
*.tsbuildinfo

# env / secrets
.env
.env.local
.env.*.local

# terraform — 상태/비밀/캐시는 절대 커밋 금지(토큰·키 포함)
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
crash.log
crash.*.log
.terraform.lock.hcl
*_oci_api_key.pem
oci_api_key*.pem

# generated font artifacts
*.woff
*.woff2
*.ttf
*.otf
# 예외: self-host 벤더 폰트는 반드시 커밋(런타임 CDN 0·오프라인). 위 *.woff2 규칙 무시.
!static-apps/gwangclick/vendor/pretendard/woff2-dynamic-subset/*.woff2
!packages/**/assets/**

# logs / os
*.log
.DS_Store
