# ── webapp 배포 환경변수 (.env.example) ──
# 복사해서 사용:  cp .env.example .env  후 값 채우기. .env 는 커밋 금지.
# docker compose / 비도커(process) 양쪽에서 공통으로 쓰는 변수들.

# ── 공개 도메인 (SEO·OG·절대 URL 생성에 사용) ──
# 예) https://yourdomain.com  (TLS 적용 후 https). 로컬 테스트는 http://localhost.
NEXT_PUBLIC_SITE_URL=http://localhost

# ── 폰트 엔진 주소 (앱 BFF가 서버측에서 호출) ──
# docker compose: 서비스명 기반(http://engine:8000).
# 비도커(process): http://127.0.0.1:8000.
ENGINE_URL=http://engine:8000

# ── 엔진 CORS 화이트리스트 (쉼표구분, 와일드카드 금지) ──
# 앱 BFF가 서버측에서 호출하므로 보조 방어선이지만, 운영 도메인을 넣어 둔다.
# 예) https://yourdomain.com
ALLOWED_ORIGINS=http://localhost

# ── 폰트 엔진 (비도커 process 방식에서만 사용) ──
# 도커에서는 컨테이너가 0.0.0.0:8000 으로 고정 바인딩하므로 불필요.
ENGINE_HOST=127.0.0.1
ENGINE_PORT=8000

# 프론트엔드(브라우저)가 직접 호출해야 하는 경우의 엔진 주소(보통 미사용 — BFF 경유).
NEXT_PUBLIC_ENGINE_URL=http://127.0.0.1:8000

# ── BASE_PATH (앱별 서브경로) ──
# docker compose 에서는 각 서비스가 자체 BASE_PATH 를 주입하므로 보통 건드릴 필요 없음.
# 로컬에서 단일 앱을 루트로 띄우고 싶을 때만 BASE_PATH="" 로 덮어쓴다.
# 참고 값: home="" / font=/font / sticker=/sticker / sign=/sign / kit=/kit / textmoji=/textmoji

# ── AI 방식 (Phase 2 — 유료 사용자 전용, 기본 OFF) ──
# 비용 발생! 켜기 전 반드시 과금 정책 확인. 기본은 비활성.
AI_ENABLED=false
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
